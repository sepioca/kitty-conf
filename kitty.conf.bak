# BEGIN_KITTY_FONTS
font_family      family="CodeNewRoman Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size 16.0
force_ltr no

# Decorations and Display
hide_window_decorations yes
single_window_padding_width 12

# Background
# background_image /home/jj/Pictures/anime-style-boy-girl-couple.jpg
background_image_layout cscaled
background_opacity 0.8
background_blur 32
# END_KITTY_FONTS
